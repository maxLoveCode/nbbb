# 服务器配置
PORT=3000
NODE_ENV=production

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=admin
DB_PASSWORD=your_database_password

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here
TOKEN_EXPIRES_IN=30d

# 微信小程序配置
WX_APPID=your_wechat_appid_here
WX_SECRET=your_wechat_secret_here

# 聚水潭（可选：不配则可将 backend/.jst_token.json 从示例复制并填值，或运行 scripts/refresh_jst_token.js）
# JST_PARTNER_ID=
# JST_APP_SECRET=
# JST_PARTNER_KEY=
# JST_REFRESH_TOKEN=
