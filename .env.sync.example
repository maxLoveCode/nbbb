# Production database: source of truth.
# Use a read-only account when possible.
PROD_DB_HOST=prod-db.example.com
PROD_DB_PORT=5432
PROD_DB_NAME=ecommerce
PROD_DB_USER=readonly_user
PROD_DB_PASSWORD=replace_me

# Staging database: sync target.
# This database will have selected tables truncated when --apply is used.
STAGING_DB_HOST=staging-db.example.com
STAGING_DB_PORT=5432
STAGING_DB_NAME=ecommerce_staging
STAGING_DB_USER=staging_admin
STAGING_DB_PASSWORD=replace_me

# Optional: override default table list.
# Keep users, user_sessions, orders, order_items, order_payments, addresses,
# shopping_cart, favorites, and payment-related data out unless you have a
# deliberate anonymization process.
# SYNC_TABLES="listed_products product_extras category_page_categories category_page_products homepage_banners homepage_lower_swiper homepage_three_images"

# Optional: store dumps somewhere outside the repo in CI.
# SYNC_BACKUP_DIR=backups/db-sync
